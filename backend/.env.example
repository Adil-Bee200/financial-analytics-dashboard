APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_predictor

# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stock_predictor

DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Worker (EOD ingest + nightly training)
WORKER_SYMBOLS=AAPL,MSFT,AMZN,GOOGL,META,NVDA,TSLA
WORKER_TIMEZONE=America/New_York
WORKER_DAILY_HOUR=22
WORKER_DAILY_MINUTE=5
WORKER_INGEST_PERIOD=1y
WORKER_FETCH_TICKER_INFO=true
WORKER_TRAIN_MIN_ROWS=60
WORKER_RUN_ON_START=false
